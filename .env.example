# ---------------------------------------------------------------------------
# te · studio · environment configuration
# ---------------------------------------------------------------------------
#
# Copy this file to ".env.local" and fill in the values you need.
#   cp .env.example .env.local
#
# Only FAL_KEY is strictly required to generate images. Everything else is
# optional and the app will fall back to safe defaults.
# ---------------------------------------------------------------------------

# Required. Your fal.ai API key — sign up at https://fal.ai and grab one from
# the dashboard. This should be a key with the API scope (the default).
# Without this the app loads but generation will fail.
FAL_KEY=

# Optional. A fal.ai key with the ADMIN scope. Used only for the account
# billing endpoint (/v1/account/billing) so the dashboard can show your
# remaining credit balance. Standard API-scope keys 403 on that endpoint.
#
# Create one at https://fal.ai/dashboard/keys → "Create new key" → scope
# "Admin". You can leave this empty — the credits chip and dashboard card
# just hide silently when it's missing.
FAL_ADMIN_KEY=

# Optional. If set, the app requires this password before letting anyone in.
# Leave blank (or remove the line entirely) to run with no password gate —
# fine for local-only use; not recommended if anything else on your network
# can reach the dev server.
APP_PASSWORD=

# Optional. Required only when APP_PASSWORD is set. Used to sign the auth
# cookie. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=
